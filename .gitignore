#sam.yaml
#.yaml

# Lambda layers - exclude all library files and directories
backend/AWS/lambda/layers/*/python/lib/**
backend/AWS/lambda/layers/*/python/bin/**
backend/AWS/lambda/layers/*/python/include/**
backend/AWS/lambda/layers/*/python/share/**
backend/AWS/lambda/layers/*/python/site-packages/**
backend/AWS/lambda/layers/*/python/**/__pycache__/**
backend/AWS/lambda/layers/*/python/**/*.dist-info/**
backend/AWS/lambda/layers/*/python/**/*.egg-info/**
backend/AWS/lambda/layers/*/python/**/*.so
backend/AWS/lambda/layers/*/python/**/*.dylib
backend/AWS/lambda/layers/*/python/**/*.dll

# Exclude specific common library directories by name
