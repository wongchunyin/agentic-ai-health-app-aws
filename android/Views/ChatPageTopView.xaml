<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LiveWell.Views.ChatPageTopView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ImageButton x:Name="NewSessionButton"
                     Grid.Column="1"
                     Source="plus_circled_icon.svg"
                     WidthRequest="10"
                     HeightRequest="10"
                     Margin="10,0"
                     Scale="0.7"
                     Clicked="NewSessionButton_Clicked"/>
        
        <Picker x:Name="SessionPicker"
                Grid.Column="2"
                Title="New Chat Session"
                FontSize="15"
                SelectedIndexChanged="SessionPicker_SelectedIndexChanged">
        </Picker>
        <Entry x:Name="SessionNameEntry"
               Grid.Column="2"
               Placeholder="Enter session name"
               FontSize="15"
               IsVisible="False"/>

        <ImageButton x:Name="RenameSessionButton"
                     Grid.Column="3"
                     Source="edit_icon.svg"
                     WidthRequest="15"
                     HeightRequest="15"
                     Margin="10,0"
                     Scale="0.7"
                     Clicked="RenameSessionButton_Clicked"/>
        <ImageButton x:Name="AcceptRenameButton"
                     Grid.Column="3"
                     Source="accept_icon.png"
                     WidthRequest="15"
                     HeightRequest="15"
                     Margin="10,0"
                     Scale="0.7"
                     Clicked="AcceptRenameButton_Clicked"
                     IsVisible="False"/>
        
        <ImageButton x:Name="DeleteSessionButton"
                     Grid.Column="4"
                     Source="trash_icon.svg"
                     WidthRequest="15"
                     HeightRequest="15"
                     Margin="10,0"
                     Scale="0.7"
                     Clicked="DeleteSessionButton_Clicked"/>

    </Grid>
</ContentView>
