<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LiveWell.Views.FrailtyHistoryView">
    <Frame CornerRadius="12" Padding="12" Margin="0,0,0,10" BackgroundColor="#FFFFFF" HasShadow="True">
        <Grid>
            <VerticalStackLayout Spacing="6" HorizontalOptions="Start">
                <Label x:Name="DateLabel" Text="25/09/2025" FontAttributes="Bold" FontSize="16" />
                <HorizontalStackLayout Spacing="12">
                    <Label Text="Frailty Scale:" FontAttributes="Bold" />
                    <Label x:Name="ScaleLabel" Text="Default" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
            <Label x:Name="ScoreLabel" Text="1" TextColor="Green" FontSize="25" HorizontalOptions="End" Padding="10,0"/>
        </Grid>
    </Frame>
</ContentView>
